<?xml version="1.0" encoding="UTF-8"?>
<window>
	<zorder>6</zorder>
	<controls>
		<control type="image">
			<description>Background</description>
			<posx>0</posx>
			<posy>0</posy>
			<width>1920</width>
			<height>1080</height>
			<texture>black.png</texture>
			<aspectratio>scale</aspectratio>
			<animation effect="fade" start="0" end="100" time="500">WindowOpen</animation>
		</control>
		<control type="videowindow" id="300">
			<description>Video window</description>
			<posx>0</posx>
			<posy>0</posy>
			<width>1920</width>
			<height>1080</height>
			<visible>true</visible>
		</control>
		<control type="group">
			<visible>!String.IsEqual(Window.Property(ImmichScreensaver.Images),hide)</visible>
			<animation type="Conditional" condition="String.IsEqual(Window.Property(ImmichScreensaver.Fade1),1)">
				<effect type="fade" start="100" end="0" time="1000"/>
			</animation>
			<control type="image" id="100">
				<description>Image 1</description>
				<posx>0</posx>
				<posy>0</posy>
				<width>1920</width>
				<height>1080</height>
				<texture background="true"></texture>
				<aspectratio>keep</aspectratio>
				<fadetime>0</fadetime>
			</control>
		</control>
		<control type="group">
			<visible>!String.IsEqual(Window.Property(ImmichScreensaver.Images),hide)</visible>
			<animation type="Conditional" condition="String.IsEqual(Window.Property(ImmichScreensaver.Fade2),1)">
				<effect type="fade" start="100" end="0" time="1000"/>
			</animation>
			<control type="image" id="101">
				<description>Image 2</description>
				<posx>0</posx>
				<posy>0</posy>
				<width>1920</width>
				<height>1080</height>
				<texture background="true"></texture>
				<aspectratio>keep</aspectratio>
				<fadetime>0</fadetime>
			</control>
		</control>
		<control type="label" id="200">
			<description>Error label</description>
			<posx>0</posx>
			<posy>490</posy>
			<width>1920</width>
			<height>100</height>
			<align>center</align>
			<aligny>center</aligny>
			<font>font13</font>
			<textcolor>white</textcolor>
			<shadowcolor>black</shadowcolor>
			<visible>String.IsEqual(Window.Property(ImmichScreensaver.Error),show)</visible>
		</control>
	</controls>
</window>
