<?xml version="1.0" encoding="UTF-8"?>
<addons>
  <addon id="screensaver.immich" name="Immich Screensaver" version="0.0.1" provider-name="skibish">
  	<requires>
  		<import addon="xbmc.python" version="3.0.0"/>
  	</requires>
  	<extension point="xbmc.ui.screensaver" library="entrypointscreensaver.py"/>
  	<extension point="xbmc.python.script" library="entrypointscript.py">
  		<provides>video</provides>
  	</extension>
  	<extension point="xbmc.addon.metadata">
  		<summary lang="en">Screensaver that displays photos and videos from Immich</summary>
  		<description lang="en">Connects to your Immich server and shows a random slideshow of your photos and muted videos as a screensaver. Uses Immich thumbnail and video playback endpoints directly. Configure your Immich server URL and API key in the add-on settings.</description>
  		<platform>all</platform>
  		<license>GPL-3.0-only</license>
  		<news>v0.0.1: Initial public release.</news>
  	</extension>
  </addon>

  <addon id="repository.skibish.kodi" name="Skibish Kodi Add-ons" version="0.0.1" provider-name="skibish">
  	<extension point="xbmc.addon.repository" name="Skibish Kodi Add-ons">
  		<dir>
  			<info compressed="false">https://raw.githubusercontent.com/skibish/kodi-addons/main/zips/addons.xml</info>
  			<checksum>https://raw.githubusercontent.com/skibish/kodi-addons/main/zips/addons.xml.md5</checksum>
  			<datadir>https://raw.githubusercontent.com/skibish/kodi-addons/main/zips/</datadir>
  			<hashes>false</hashes>
  		</dir>
  	</extension>
  	<extension point="xbmc.addon.metadata">
  		<summary lang="en">Third-party Kodi add-ons by skibish</summary>
  		<description lang="en">Install and update Kodi add-ons published in the Skibish Kodi Add-ons repository.</description>
  		<platform>all</platform>
  		<license>GPL-3.0-only</license>
  		<news>v0.0.1: Initial repository release.</news>
  	</extension>
  </addon>
</addons>
